# ==========================================
# Frontend (Flutter)
# ==========================================

# Flutter Build-Artefakte
frontend/build/
frontend/.dart_tool/
frontend/.packages
frontend/.pub-cache/
frontend/.pub/

# Android-spezifisch
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/*.keystore
frontend/android/*.jks
frontend/android/*.apk
frontend/android/*.aab
frontend/android/app/src/main/res/drawable-*/ic_launcher.png

# iOS- / macOS-spezifisch
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/flutter_export_environment.sh
frontend/ios/Flutter/ephemeral/
frontend/ios/Pods/
frontend/macos/Flutter/ephemeral/
frontend/macos/Flutter/GeneratedPluginRegistrant.swift
frontend/macos/Runner/GeneratedPluginRegistrant.h
frontend/macos/Runner/GeneratedPluginRegistrant.m
frontend/.symlinks/
frontend/DerivedData/
*.xcuserstate

# Linux-spezifisch
frontend/linux/flutter/ephemeral/
frontend/linux/flutter/generated_plugin_registrant.cc
frontend/linux/flutter/generated_plugin_registrant.h
frontend/linux/flutter/generated_plugins.cmake

# Windows-spezifisch
frontend/windows/flutter/ephemeral/
frontend/windows/flutter/generated_plugin_registrant.cc
frontend/windows/flutter/generated_plugin_registrant.h
frontend/windows/flutter/generated_plugins.cmake
frontend/cmake-build-*/

# Web-spezifisch
frontend/.web/

# Screenshots (außer das finale Mockup laut deinem Wunsch)
frontend/screenshots/*.png
!frontend/screenshots/final_mockup.png

# Zusätzliche Fixes für verbleibende Warnungen
frontend/.metadata
frontend/ios/Runner/GeneratedPluginRegistrant.*
frontend/macos/Runner/GeneratedPluginRegistrant.*